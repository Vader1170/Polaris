{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/about", "destination": "/about.html" },
    { "source": "/signin", "destination": "/signin.html" },
    { "source": "/navigator", "destination": "/navigator.html" },
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
